      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [
        {"expr": "rate(symphony_tokens_total{direction=\"input\"}[5m])", "legendFormat": "Input tokens/s"},
        {"expr": "rate(symphony_tokens_total{direction=\"output\"}[5m])", "legendFormat": "Output tokens/s"}
      ]
    },
    {
      "title": "GitHub Writebacks",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [
        {"expr": "rate(symphony_github_writebacks_total[5m])", "legendFormat": "Writebacks/s"}
      ]
    },
    {
      "title": "Active Runs Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
