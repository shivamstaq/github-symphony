  "panels": [
    {
      "title": "Active Runs",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "symphony_active_runs", "legendFormat": "Active"}],
      "fieldConfig": {
        "defaults": {
          "max": 20,
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "title": "Max Concurrent Agents",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "symphony_max_concurrent_agents", "legendFormat": "Max"}]
    },
    {
      "title": "Retry Queue Depth",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "symphony_retry_queue_depth", "legendFormat": "Retrying"}],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "title": "Sessions Started",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "symphony_sessions_started_total", "legendFormat": "Total"}]
    },
    {
