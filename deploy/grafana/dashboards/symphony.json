      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [
        {"expr": "symphony_tokens_total{direction=\"total\"}", "legendFormat": "Total Tokens"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    }
